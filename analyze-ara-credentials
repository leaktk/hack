#!/usr/bin/env python3
import json
import sys
import requests

def analyze(server, username, password):
    # Ensure server URL is formatted correctly
    server = server.rstrip('/')
    url = f"{server}/api/v1/playbooks"
    auth = (username, password)
    
    results = {
        "valid": False,
        "analysis": {},
    }

    try:
        # ARA typically uses Basic Auth via a reverse proxy or Django
        resp = requests.get(url, auth=auth, timeout=10)
        results["analysis"]["status_code"] = resp.status_code

        if resp.status_code == 200:
            data = resp.json()
            results["valid"] = True
            # Return basic metadata about the recorded data
            results["analysis"]["playbook_count"] = data.get("count", 0)
            results["analysis"]["latest_playbooks"] = [
                {"id": p.get("id"), "name": p.get("name"), "status": p.get("status")}
                for p in data.get("results", [])[:5]
            ]
        elif resp.status_code == 401:
            results["valid"] = False
            results["analysis"]["error"] = "Unauthorized: Invalid credentials"
        else:
            results["analysis"]["raw_response"] = resp.text[:128]

    except Exception as e:
        results["error"] = {"message": f"Request failed: {str(e)}"}

    return results

if __name__ == "__main__":
    if len(sys.argv) != 4:
        print(f"Usage: {sys.argv[0]} <api_server> <username> <password>")
        sys.exit(1)

    # Arguments: server, username, password
    print(json.dumps(analyze(sys.argv[1], sys.argv[2], sys.argv[3])))
