#!/usr/bin/env python3
import json
import sys
import requests

def analyze(api_token):
    headers = {"Authorization": f"Bearer {api_token}"}
    results = {
        "valid": False,
        "analysis": {},
    }

    try:
        # Check scopes to verify validity and see permissions
        resp = requests.get("https://api.sendgrid.com/v3/scopes", headers=headers)
        results["analysis"]["status_code"] = resp.status_code
        
        if resp.status_code == 200:
            results["valid"] = True
            results["analysis"]["scopes"] = resp.json().get("scopes", [])
            
            # Try to get account user info for context
            user_resp = requests.get("https://api.sendgrid.com/v3/user/profile", headers=headers)
            if user_resp.status_code == 200:
                results["analysis"]["user"] = user_resp.json()
        elif resp.status_code == 401:
            results["valid"] = False
        else:
            results["error"] = {"message": "unexpected response", "code": resp.status_code}
            
    except Exception as e:
        results["error"] = {"message": f"request failed: {e}"}

    return results

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print(f"Usage: {sys.argv[0]} <api-token>")
        sys.exit(1)

    print(json.dumps(analyze(sys.argv[1])))
