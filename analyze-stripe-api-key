#!/usr/bin/env python3
import json
import os
import sys

from http import HTTPStatus
import requests

__doc__ = f"""
USAGE
    {os.path.basename(__file__)} <api-key>

DESCRIPTION
    Validates a Stripe API key by retrieving basic account information.
"""

def analyze(api_key):
    # Stripe uses Basic Auth with the key as the username and no password
    headers = {"Authorization": f"Bearer {api_key}"}
    results = {
        "valid": False,
        "analysis": {},
    }

    try:
        # Retrieve the account object for the authenticated key
        resp = requests.get("https://api.stripe.com/v1/account", headers=headers)
        results["analysis"]["status_code"] = resp.status_code

        try:
            results["analysis"]["status"] = HTTPStatus(resp.status_code).phrase
        except ValueError:
            results["analysis"]["status"] = "Unknown"

        if resp.status_code == 200:
            account_info = resp.json()
            results["valid"] = True
            results["analysis"]["account_id"] = account_info.get("id")
            results["analysis"]["business_name"] = account_info.get("business_profile", {}).get("name")
            results["analysis"]["charges_enabled"] = account_info.get("charges_enabled")
            results["analysis"]["details_submitted"] = account_info.get("details_submitted")
            # Determine if it's test or live based on prefix
            results["analysis"]["mode"] = "test" if api_key.startswith(("sk_test_", "rk_test_", "pk_test_")) else "live"
        elif resp.status_code == 401:
            results["valid"] = False
            results["analysis"]["error"] = "Invalid API key"
        else:
            results["error"] = {"message": "unexpected response", "code": resp.status_code}
            
    except requests.exceptions.RequestException as e:
        results["error"] = {"message": f"request failed: {e}"}

    return results

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print(__doc__)
        sys.exit(1)

    print(json.dumps(analyze(sys.argv[1])))
