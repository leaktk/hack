#!/usr/bin/env python3
import base64
import hashlib
import hmac
import json
import os
import sys

from datetime import UTC
from datetime import datetime
from http import HTTPStatus

import requests

__doc__ = f"""
USAGE
    {os.path.basename(__file__)} <workspace-id> <shared-key>

DESCRIPTION
    Validates Azure Log Analytics credentials by attempting to post a 
    canary heartbeat to a custom log.
"""


def error(message, **kwargs):
    return {"message": message, **kwargs}


def build_signature(
    customer_id, shared_key, date, content_length, method, content_type, resource
):
    x_headers = "x-ms-date:" + date
    string_to_hash = (
        f"{method}\n{content_length}\n{content_type}\n{x_headers}\n{resource}"
    )
    bytes_to_hash = bytes(string_to_hash, encoding="utf-8")
    decoded_key = base64.b64decode(shared_key)
    encoded_hash = base64.b64encode(
        hmac.new(decoded_key, bytes_to_hash, digestmod=hashlib.sha256).digest()
    ).decode("utf-8")
    return f"SharedKey {customer_id}:{encoded_hash}"


def analyze(workspace_id, shared_key):
    method = "POST"
    content_type = "application/json"
    resource = "/api/logs"
    rfc1123date = datetime.now(UTC).strftime("%a, %d %b %Y %H:%M:%S GMT")
    body = json.dumps({"leaktk": "validation_check"})
    content_length = len(body)

    try:
        signature = build_signature(
            workspace_id,
            shared_key,
            rfc1123date,
            content_length,
            method,
            content_type,
            resource,
        )
    except Exception as e:
        return error(f"Failed to generate signature: {e}")

    headers = {
        "content-type": content_type,
        "Authorization": signature,
        "Log-Type": "leaktk_validation_check",
        "x-ms-date": rfc1123date,
    }

    url = f"https://{workspace_id}.ods.opinsights.azure.com{resource}?api-version=2016-04-01"

    results = {
        "valid": False,
        "analysis": {},
    }

    try:
        resp = requests.post(url, data=body, headers=headers)
        results["analysis"]["status_code"] = resp.status_code

        try:
            results["analysis"]["status"] = HTTPStatus(resp.status_code).phrase
        except ValueError:
            results["analysis"]["status"] = "Unknown"

        if resp.status_code == 200:
            results["valid"] = True
            results["analysis"][
                "note"
            ] = "Successfully posted heartbeat to 'LeakTriageCheck_CL' table."
        elif resp.status_code == 403:
            results["analysis"][
                "note"
            ] = "Forbidden: Key is likely invalid or workspace ID is wrong."
        else:
            results["error"] = error(
                "unexpected response", code=resp.status_code, raw=resp.text[:128]
            )

    except requests.exceptions.RequestException as e:
        results["error"] = error(f"request failed: {e}")

    return results


if __name__ == "__main__":
    if len(sys.argv) != 3:
        print(__doc__)
        sys.exit(1)

    print(json.dumps(analyze(*sys.argv[1:])))
